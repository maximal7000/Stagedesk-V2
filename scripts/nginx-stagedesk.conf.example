# /etc/nginx/sites-available/tag
# Stagedesk V2 — Frontend (Vite build) + ASGI-Backend via Unix-Socket.

server {
    server_name stagedesk.t410.de tag.t410.de;

    client_max_body_size 50M;

    location /admin/ {
        include proxy_params;
        proxy_pass http://unix:/run/t-ag.sock;
    }

    location /api/ {
        include proxy_params;
        proxy_pass http://unix:/run/t-ag.sock;
    }

    # WebSocket (Django Channels)
    location /ws/ {
        proxy_pass http://unix:/run/t-ag.sock;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 86400;
        proxy_send_timeout 86400;
    }

    location /django-static/ {
        alias /opt/stagedesk/backend/staticfiles/;
    }

    location /media/ {
        alias /opt/stagedesk/backend/media/;
    }

    # React-Frontend
    location / {
        root /opt/stagedesk/frontend/dist;
        index index.html;
        try_files $uri /index.html;
    }

    listen 443 ssl;
    ssl_certificate /etc/letsencrypt/live/tag.t410.de/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/tag.t410.de/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;
}

server {
    if ($host = stagedesk.t410.de) {
        return 301 https://$host$request_uri;
    }
    if ($host = tag.t410.de) {
        return 301 https://$host$request_uri;
    }
    listen 80;
    server_name stagedesk.t410.de tag.t410.de;
    return 404;
}

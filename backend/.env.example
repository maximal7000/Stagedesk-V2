# ──────────────────────────────────────────────────────────────
#  Django
# ──────────────────────────────────────────────────────────────
# In Produktion unbedingt neue Keys generieren:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=stagedesk.t410.de,tag.t410.de
DJANGO_CORS_ORIGINS=https://stagedesk.t410.de,https://tag.t410.de
DJANGO_CSRF_TRUSTED_ORIGINS=https://stagedesk.t410.de,https://tag.t410.de
# Muss zur Nginx-Location für statische Dateien passen (siehe scripts/nginx-stagedesk.conf.example)
DJANGO_STATIC_URL=/django-static/

# ──────────────────────────────────────────────────────────────
#  Datenbank (sqlite | postgres)
# ──────────────────────────────────────────────────────────────
DB_ENGINE=postgres
DB_NAME=stagedesk
DB_USER=stagedesk
DB_PASSWORD=change-me
DB_HOST=127.0.0.1
DB_PORT=5432

# ──────────────────────────────────────────────────────────────
#  Keycloak
# ──────────────────────────────────────────────────────────────
KEYCLOAK_SERVER_URL=https://auth.t410.de
KEYCLOAK_REALM=technik-ag
KEYCLOAK_CLIENT_ID=stagedesk

# ──────────────────────────────────────────────────────────────
#  E-Mail
# ──────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.strato.de
EMAIL_PORT=465
EMAIL_USE_TLS=False
EMAIL_USE_SSL=True
EMAIL_HOST_USER=no-reply@wirklauendeinedaten.de
EMAIL_HOST_PASSWORD=change-me
DEFAULT_FROM_EMAIL=no-reply@wirklauendeinedaten.de

# ──────────────────────────────────────────────────────────────
#  Zammad (Veranstaltungsplaner)
# ──────────────────────────────────────────────────────────────
ZAMMAD_URL=https://zammad.example.com
ZAMMAD_TOKEN=

# ──────────────────────────────────────────────────────────────
#  Discord (Veranstaltungsplaner)
# ──────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_CATEGORY_ID=
